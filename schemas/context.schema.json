{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aethercursor.local/schemas/context.schema.json",
  "title": "ContextProtocol",
  "type": "object",
  "additionalProperties": false,
  "required": ["context_id", "created_at", "source", "selection", "content", "metadata", "privacy"],
  "properties": {
    "context_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_name", "window_title", "url"],
      "properties": {
        "app_name": {
          "type": ["string", "null"]
        },
        "window_title": {
          "type": ["string", "null"]
        },
        "url": {
          "type": ["string", "null"]
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "bounds", "display_scale"],
      "properties": {
        "type": {
          "enum": ["text", "ocr_text", "image_region", "screen_region", "app_metadata"]
        },
        "bounds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "width": {
              "type": "number",
              "minimum": 0
            },
            "height": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "display_scale": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "shape": {
          "enum": ["focus", "rect", "lasso", "object_snap"]
        },
        "path": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y"],
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_text", "ocr_text", "image_ref"],
      "properties": {
        "selected_text": {
          "type": ["string", "null"]
        },
        "ocr_text": {
          "type": ["string", "null"]
        },
        "image_ref": {
          "type": ["string", "null"]
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "content_guess", "confidence"],
      "properties": {
        "language": {
          "type": "string"
        },
        "content_guess": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cloud_allowed", "contains_sensitive_guess", "user_confirmed_upload"],
      "properties": {
        "cloud_allowed": {
          "type": "boolean"
        },
        "contains_sensitive_guess": {
          "type": "boolean"
        },
        "user_confirmed_upload": {
          "type": "boolean"
        }
      }
    }
  }
}
