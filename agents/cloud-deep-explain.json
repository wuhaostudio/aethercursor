{
  "id": "agent.cloud.deep-explain",
  "name": "深度解释",
  "version": "0.1.0",
  "description": "提供深入、详细的解释，包含背景知识和示例。",
  "capabilities": ["explain", "question_answering"],
  "input_types": ["text", "ocr_text", "screen_region", "image_region"],
  "output_types": ["markdown", "plain_text"],
  "execution_mode": "cloud",
  "latency_level": "medium",
  "cost_level": "medium",
  "required_permissions": ["screen_region_read", "cloud_upload"],
  "privacy_policy": {
    "requires_upload": true,
    "sensitive_data_allowed": false,
    "user_confirmation": "first_time"
  }
}
